+    def _expand_style_crops(images: list[torch.Tensor], n: int = 2) -> list[torch.Tensor]:
+        """Split each reference into an n x n grid of crops, order-shuffled: composition/pose cannot
+        survive, while palette/texture/lighting are present in every crop. n=2 (quadrants) keeps some
+        object-level content per crop; n=4 (fine tiles) leaves mostly texture/palette-level content."""
